{
  "name": "jz-hook",
  "version": "0.4.0-hook.1",
  "description": "Modern functional JS compiling to WASM — optimized for Xahau Hook smart contracts",
  "main": "index.js",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./wasi": "./wasi.js",
    "./interop": "./interop/nanbox.js",
    "./interop/nanbox": "./interop/nanbox.js",
    "./types": "./types/hook.d.ts"
  },
  "files": [
    "index.js",
    "cli.js",
    "wasi.js",
    "src",
    "module",
    "interop",
    "types",
    "README.md"
  ],
  "bin": {
    "jz": "cli.js",
    "jz-hook": "cli.js"
  },
  "scripts": {
    "test": "npm run test:hook && npm run test:hook-pin && npm run test:hook-snapshots",
    "test:jz": "node test/index.js",
    "test262": "node test/test262.js",
    "test262:builtins": "node test/test262-builtins.js",
    "test:hook": "node test/hook/index.js",
    "bench": "node bench/bench.mjs",
    "bench:size": "node scripts/bench-size.mjs",
    "bench:compile": "node scripts/bench-compile.mjs",
    "test:bench-pin": "node test/bench-pin.js",
    "test:hook-pin": "node test/hook-pin.js",
    "test:hook-snapshots": "node test/hook/samples-wat.js",
    "test:hook-snapshots:update": "UPDATE_SNAPSHOTS=1 npm run test:hook-snapshots",
    "prepublishOnly": "npm run test:hook && npm run test:hook-pin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dy/jz.git"
  },
  "bugs": {
    "url": "https://github.com/dy/jz/issues"
  },
  "homepage": "https://github.com/dy/jz#readme",
  "author": "Dmitry Iv",
  "license": "MIT",
  "dependencies": {
    "subscript": "^10.4.8",
    "watr": "^4.6.5"
  },
  "keywords": [
    "javascript",
    "webassembly",
    "compiler",
    "functional",
    "minimal",
    "wasm",
    "xahau",
    "hooks",
    "smart-contract",
    "blockchain"
  ],
  "devDependencies": {
    "tst": "^9.4.0"
  }
}
